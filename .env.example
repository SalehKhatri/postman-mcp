# Postman MCP Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Postman API key
# Get this from: https://go.postman.co/settings/me/api-keys
POSTMAN_API_KEY=your_postman_api_key_here

# Optional: API base URL (defaults to official Postman API)
# POSTMAN_API_BASE_URL=https://api.getpostman.com

# Optional: Request timeout in milliseconds (defaults to 30000)
# REQUEST_TIMEOUT=30000

# Optional: Enable debug logging (defaults to false)
# DEBUG=false
