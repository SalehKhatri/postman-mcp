{
  "name": "postman-mcp",
  "version": "1.0.1",
  "main": "./dist/index.js`",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "postman-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "postman",
    "mcp",
    "model context protocol",
    "typescript",
    "claude"
  ],
  "author": "Saleh Khatri <saleh@salehkhatri.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/salehkhatri/postman-mcp"
  },
  "license": "MIT",
  "description": "A Model Context Protocol (MCP) server that provides seamless integration with the Postman API. This package enables AI assistants and applications to interact with Postman workspaces, collections, requests, environments, and folders programmatically.",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "axios": "^1.10.0",
    "dotenv": "^16.6.1",
    "zod": "^3.25.67",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
